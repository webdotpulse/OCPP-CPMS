// Open-Source OCPP CMS - Prisma Schema
// Clean, production-ready schema for OCPP 1.6 Charge Point Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Admin user accounts
model User {
  id                  Int       @id @default(autoincrement())
  name                String?
  email               String    @unique
  password            String
  role                String    @default("admin")
  userType            String    @default("private")
  companyName         String?
  address             String?
  phone               String?
  taxNumber           String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorMethod     String?
  twoFactorSecret     String?
  twoFactorCode       String?
  twoFactorCodeExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  chargingStations ChargingStation[]
  chargers         Charger[]
  rfidUsers        RfidUser[]
  chargeGroupUsers ChargeGroupUser[]
}

// Charging station / Site location
model ChargingStation {
  id                      Int      @id @default(autoincrement())
  station_name            String
  street_name             String
  city                    String
  state                   String?
  postal_code             String
  country                 String?
  latitude                Float
  longitude               Float
  on_site_person_name     String?
  on_site_contact_details String?
  emergency_contact       String?
  status                  String   @default("active")
  maxPower                Float? // Maximum allowed capacity in kW/Amps
  owner_id                Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  owner    User      @relation(fields: [owner_id], references: [id])
  chargers Charger[]
}

// Charging Point / Charger
model Charger {
  chargerAlerts        ChargerAlert[]
  charger_id           Int            @id @default(autoincrement())
  model                String
  name                 String         @unique
  manufacturer         String
  serial_number        String         @unique
  manufacturing_date   DateTime?
  power_capacity       Float
  status               String         @default("offline")
  last_heartbeat       DateTime       @default("1970-01-01T00:00:00.000Z")
  firmware_version     String
  service_contacts     String
  latitude             Float?
  longitude            Float?
  thirdPartyBackendUrl String?
  owner_id             Int
  charging_station_id  Int
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  owner            User                   @relation(fields: [owner_id], references: [id])
  chargingStation  ChargingStation        @relation(fields: [charging_station_id], references: [id])
  evses            Evse[]
  transactions     Transaction[]
  ocppLogs         OcppLog[]
  rfidSessions     RfidSession[]
  tariffs          Tariff[]
  chargeGroup      ChargeGroup?           @relation(fields: [chargeGroupId], references: [id], onDelete: SetNull)
  chargeGroupId    Int?
  configurations   ChargerConfiguration[]
  chargingProfiles ChargingProfile[]
  meterValues      MeterValue[]
  deviceComponents DeviceComponent[]
  quirkProfile     ChargerQuirkProfile?   @relation(fields: [quirkProfileId], references: [id], onDelete: SetNull)
  quirkProfileId   Int?
}

model ChargerQuirkProfile {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  rules       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  chargers Charger[]
}

model Evse {
  id         Int      @id @default(autoincrement())
  evse_id    Int
  charger_id Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  charger    Charger     @relation(fields: [charger_id], references: [charger_id])
  connectors Connector[]

  @@unique([charger_id, evse_id])
}

// Charge connector (multiple per evse)
model Connector {
  connector_id   Int      @id @default(autoincrement())
  connector_name String   @default("Connector 1")
  status         String
  current_type   String
  max_current    Float?
  max_power      Float?
  mac_address    String?
  evse_id        Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  evse Evse @relation(fields: [evse_id], references: [id])
}

// RFID tag whitelist
model RfidUser {
  rfid_user_id Int      @id @default(autoincrement())
  rfid_tag     String   @unique
  external_id  String?
  name         String
  email        String?
  phone        String?
  company_name String?
  address      String?
  type         String   @default("postpaid")
  active       Boolean  @default(true)
  owner_id     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        User          @relation(fields: [owner_id], references: [id])
  rfidSessions RfidSession[]
}

// RFID post-paid charging sessions
model RfidSession {
  id                Int       @id @default(autoincrement())
  transactionId     String    @unique
  rfidUserId        Int
  charger_id        Int
  connectorName     String
  charger           Charger   @relation(fields: [charger_id], references: [charger_id])
  startTime         DateTime  @default(now())
  endTime           DateTime?
  initialMeterValue Float?
  finalMeterValue   Float?
  energyConsumed    Float     @default(0)
  currentPower      Float?    @default(0)
  soc               Float?
  current           Float?
  voltage           Float?
  tariffRate        Float?
  amountDue         Float     @default(0)
  status            String    @default("charging")
  stopReason        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rfidUser RfidUser @relation(fields: [rfidUserId], references: [rfid_user_id])
}

// Simplified transaction tracking
model Transaction {
  id                Int       @id @default(autoincrement())
  transactionId     String
  connectorName     String
  charger_id        Int
  charger           Charger   @relation(fields: [charger_id], references: [charger_id])
  startTime         DateTime  @default(now())
  endTime           DateTime?
  initialMeterValue Float?
  finalMeterValue   Float?
  energyConsumed    Float     @default(0)
  currentPower      Float?    @default(0)
  soc               Float?
  current           Float?
  voltage           Float?
  status            String    @default("initiated")
  stopReason        String?
  idTag             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([charger_id])
  @@index([status])
}

// OCPP message logging for debugging
model OcppLog {
  id            Int      @id @default(autoincrement())
  chargerId     Int
  charger       Charger  @relation(fields: [chargerId], references: [charger_id])
  transactionId String?
  timestamp     DateTime @default(now())
  direction     String
  message       String

  @@index([chargerId])
}

// Optional: Tariff for pricing
model Tariff {
  tariff_id        Int      @id @default(autoincrement())
  tariff_name      String   @unique
  charge           Float
  electricity_rate Float
  tariffType       String   @default("FIXED") // "FIXED" or "DYNAMIC_EPEX"
  country          String?  // "BE" or "NL"
  markupPerKwh     Float?
  taxPercentage    Float?
  fixedFeePerMonth Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chargers         Charger[]
  chargeGroupUsers ChargeGroupUser[]
}

model EpexSpotPrice {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime
  country     String
  pricePerMwh Float

  @@unique([timestamp, country])
}

// Payment Transactions (for Stripe, Mollie, etc.)
model PaymentTransaction {
  id              Int      @id @default(autoincrement())
  transactionId   String   @unique
  provider        String // "stripe", "mollie", etc.
  paymentIntentId String? // ID from provider
  amount          Float
  currency        String   @default("EUR")
  status          String   @default("pending") // "pending", "succeeded", "failed"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// OCPI Endpoints for roaming
model OcpiEndpoint {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  token     String // Token used for auth
  version   String   @default("2.2.1")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChargeGroup {
  id                  Int      @id @default(autoincrement())
  name                String
  description         String?
  maxPower            Float? // Maximum allowed capacity in kW/Amps
  maxAmperage         Float?
  phaseUnbalanceLimit Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  chargers Charger[]
  users    ChargeGroupUser[]
}

model ChargerConfiguration {
  id        Int     @id @default(autoincrement())
  chargerId Int
  key       String
  value     String
  readonly  Boolean @default(false)
  charger   Charger @relation(fields: [chargerId], references: [charger_id], onDelete: Cascade)

  @@unique([chargerId, key])
}

model ChargeGroupUser {
  chargeGroupId Int
  userId        Int
  tariffId      Int?
  chargeGroup   ChargeGroup @relation(fields: [chargeGroupId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariff        Tariff?     @relation(fields: [tariffId], references: [tariff_id])

  @@id([chargeGroupId, userId])
}

// Unrecognized or rejected OCPP connections
model UnrecognizedConnection {
  id            Int      @id @default(autoincrement())
  chargePointId String
  ipAddress     String?
  reason        String
  timestamp     DateTime @default(now())
}

// OCPP Smart Charging Profiles applied to chargers
model ChargingProfile {
  id                     Int       @id @default(autoincrement())
  chargerId              Int
  connectorId            Int
  chargingProfileId      Int
  transactionId          String?
  stackLevel             Int
  chargingProfilePurpose String // e.g. "ChargePointMaxProfile", "TxDefaultProfile", "TxProfile"
  chargingProfileKind    String // e.g. "Absolute", "Recurring", "Relative"
  recurrencyKind         String?
  validFrom              DateTime?
  validTo                DateTime?
  chargingSchedule       Json // Store the complex charging schedule object
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  charger Charger @relation(fields: [chargerId], references: [charger_id], onDelete: Cascade)

  @@unique([chargerId, chargingProfileId])
}

// OICP Endpoints for roaming
model OicpEndpoint {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  token     String // Token used for auth
  version   String   @default("2.3.0")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Smart Charging Profiles applied to chargers
model ConfigurationProfile {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ConfigurationProfileItem[]
}

model ConfigurationProfileItem {
  id        Int                  @id @default(autoincrement())
  profileId Int
  key       String
  value     String
  profile   ConfigurationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, key])
}

model MeterValue {
  id            Int      @id @default(autoincrement())
  transactionId String
  chargerId     Int
  connectorId   Int?
  energy        Float?
  power         Float?
  soc           Float?
  current       Float?
  voltage       Float?
  current_L1    Float?
  current_L2    Float?
  current_L3    Float?
  voltage_L1    Float?
  voltage_L2    Float?
  voltage_L3    Float?
  timestamp     DateTime @default(now())

  charger Charger @relation(fields: [chargerId], references: [charger_id], onDelete: Cascade)

  @@index([transactionId])
  @@index([chargerId])
}

model DeviceComponent {
  id          Int     @id @default(autoincrement())
  chargerId   Int
  name        String
  instance    String?
  evseId      Int?
  connectorId Int?

  charger   Charger          @relation(fields: [chargerId], references: [charger_id], onDelete: Cascade)
  variables DeviceVariable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Note: For unique constraints with nullable fields, Prisma might allow multiple NULLs in standard SQL.
}

model DeviceVariable {
  id          Int     @id @default(autoincrement())
  componentId Int
  name        String
  instance    String?

  component  DeviceComponent     @relation(fields: [componentId], references: [id], onDelete: Cascade)
  attributes VariableAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VariableAttribute {
  id         Int     @id @default(autoincrement())
  variableId Int
  type       String  @default("Actual")
  value      String?
  mutability String?
  persistent Boolean @default(false)
  constant   Boolean @default(false)

  variable DeviceVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variableId, type])
}

model ChargerAlert {
  id          Int      @id @default(autoincrement())
  chargerId   Int
  eventId     Int
  timestamp   DateTime
  severity    Int
  component   String
  variable    String
  actualValue String

  charger Charger @relation(fields: [chargerId], references: [charger_id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
